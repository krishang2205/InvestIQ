{
    "name": "investiq-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev --prefix frontend\" \".venv\\Scripts\\python.exe backend/app.py\"",
        "install:all": "npm install && npm install --prefix frontend && pip install -r backend/requirements.txt",
        "build": "npm run build --prefix frontend",
        "start": "cd backend && gunicorn -c gunicorn_config.py app:app"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}